{
  "name": "aigc-core",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.2",
  "type": "module",
  "scripts": {
    "dev:ui": "vite",
    "build:ui": "vite build",
    "preview:ui": "vite preview --host 127.0.0.1 --port 4102",
    "dev": "tauri dev",
    "lean:dev": "bash tools/dev/lean-dev.sh",
    "build": "tauri build",
    "clean:heavy": "bash tools/dev/clean-heavy-artifacts.sh",
    "clean:full-local": "bash tools/dev/clean-full-local.sh",
    "lint": "eslint .",
    "ui:lint": "pnpm lint && stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "ui:typecheck": "tsc --noEmit",
    "ui:gate:static": "pnpm ui:lint && pnpm ui:typecheck",
    "ui:test:visual": "playwright test tests/ui --grep @visual",
    "ui:test:a11y": "playwright test tests/ui --grep @a11y",
    "ui:gate:regression": "pnpm ui:test:visual && pnpm ui:test:a11y",
    "ui:gate": "pnpm ui:gate:static && pnpm ui:gate:regression",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "playwright test tests/ui",
    "gate:all": "node tools/gates/run-all.mjs",
    "ui:test:visual:update": "playwright test tests/ui --grep @visual --update-snapshots",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "pnpm git:guard:branch && pnpm git:guard:atomic && pnpm git:guard:generated && pnpm git:guard:large-files && pnpm git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.0.5",
    "commitizen": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.8.2",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "vitest": "^2.0.5",
    "web-vitals": "^5.1.0"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
