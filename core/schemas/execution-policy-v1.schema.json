{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aigccore.local/schemas/execution-policy-v1.schema.json",
  "title": "ExecutionPolicyV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "backend_id",
    "input_tree_sha256",
    "image_id",
    "argv",
    "working_directory",
    "filesystem",
    "network",
    "process",
    "resources",
    "environment",
    "export",
    "evidence"
  ],
  "properties": {
    "schema_version": { "const": "AIGC_EXECUTION_POLICY_V1" },
    "policy_id": { "type": "string", "minLength": 1 },
    "backend_id": { "const": "OCI_ZERO_EGRESS_V1" },
    "input_tree_sha256": { "$ref": "#/$defs/sha256" },
    "image_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "working_directory": { "type": "string", "pattern": "^/" },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "immutable_input_path",
        "writable_workspace_path",
        "output_path_allowlist",
        "max_output_bytes",
        "host_mounts_allowed"
      ],
      "properties": {
        "immutable_input_path": { "type": "string", "pattern": "^/" },
        "writable_workspace_path": { "type": "string", "pattern": "^/" },
        "output_path_allowlist": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "max_output_bytes": { "type": "integer", "minimum": 1 },
        "host_mounts_allowed": { "const": false }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "blocked_classes"],
      "properties": {
        "mode": { "const": "DENY_ALL" },
        "blocked_classes": {
          "type": "array",
          "uniqueItems": true,
          "allOf": [
            {
              "contains": { "const": "DNS" }
            },
            {
              "contains": { "const": "IPV4" }
            },
            {
              "contains": { "const": "IPV6" }
            },
            {
              "contains": { "const": "METADATA" }
            },
            {
              "contains": { "const": "LOOPBACK" }
            },
            {
              "contains": { "const": "UNIX_SOCKET" }
            },
            {
              "contains": { "const": "PROXY" }
            }
          ],
          "items": {
            "enum": [
              "DNS",
              "IPV4",
              "IPV6",
              "METADATA",
              "LOOPBACK",
              "UNIX_SOCKET",
              "PROXY"
            ]
          }
        }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "child_processes_allowed",
        "pid_limit",
        "wall_time_ms",
        "controller_death_cleanup_required",
        "trusted_init_required"
      ],
      "properties": {
        "child_processes_allowed": { "type": "boolean" },
        "pid_limit": { "type": "integer", "minimum": 1 },
        "wall_time_ms": { "type": "integer", "minimum": 1 },
        "controller_death_cleanup_required": { "const": true },
        "trusted_init_required": { "const": true }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_bytes",
        "memory_swap_bytes",
        "cpu_quota_millis",
        "workspace_bytes",
        "max_file_bytes",
        "max_open_files"
      ],
      "properties": {
        "memory_bytes": { "type": "integer", "minimum": 1 },
        "memory_swap_bytes": { "type": "integer", "minimum": 1 },
        "cpu_quota_millis": { "type": "integer", "minimum": 1 },
        "workspace_bytes": { "type": "integer", "minimum": 1 },
        "max_file_bytes": { "type": "integer", "minimum": 1 },
        "max_open_files": { "type": "integer", "minimum": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_keys", "secrets", "synthetic_home", "synthetic_tmp"],
      "properties": {
        "allowed_keys": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "not": {
              "pattern": "(TOKEN|SECRET|PASSWORD|PROXY|^AWS_|^GITHUB_|^DOCKER_|^SSH_)"
            }
          }
        },
        "secrets": { "const": "NONE" },
        "synthetic_home": { "type": "string", "pattern": "^/" },
        "synthetic_tmp": { "type": "string", "pattern": "^/" }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patch_only",
        "review_required",
        "reviewer_kind",
        "max_patch_bytes"
      ],
      "properties": {
        "patch_only": { "const": true },
        "review_required": { "const": true },
        "reviewer_kind": { "type": "string", "minLength": 1 },
        "max_patch_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_control_ids",
        "require_effective_policy_readback",
        "require_zero_residue",
        "maximum_claim"
      ],
      "properties": {
        "required_control_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "require_effective_policy_readback": { "const": true },
        "require_zero_residue": { "const": true },
        "maximum_claim": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
